{
  "name": "dtc-starter-monorepo",
  "private": false,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.0.14"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "^2.14.2",
    "@medusajs/framework": "^2.14.2",
    "@medusajs/medusa": "^2.14.2"
  }
}
